{
  "name": "omniplan-ai",
  "productName": "OmniPlan AI",
  "private": true,
  "version": "2.1.0",
  "description": "Executive Life OS - Planner, Calendar, Goals & AI",
  "author": "OmniPlan",
  "repository": {
    "type": "git",
    "url": "https://github.com/RhyGPU/Planner"
  },
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "npm run build && electron .",
    "start:dev": "cross-env VITE_DEV_SERVER_URL=http://localhost:3000 electron .",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "cap:sync": "npx cap sync",
    "cap:ios": "npx cap open ios",
    "cap:android": "npx cap open android",
    "build:mobile": "vite build && npx cap sync"
  },
  "dependencies": {
    "@capacitor/core": "^8.2.0",
    "@capacitor/local-notifications": "^8.0.2",
    "@capacitor/preferences": "^8.0.1",
    "@fontsource/inter": "^5.2.8",
    "@google/genai": "^1.38.0",
    "capacitor-secure-storage-plugin": "^0.13.0",
    "imapflow": "^1.2.13",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.2.0",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.24",
    "cross-env": "^7.0.3",
    "electron": "^26.0.0",
    "electron-builder": "^24.6.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.omniplan.app",
    "productName": "OmniPlan AI",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron-main.cjs",
      "preload.cjs",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "requestedExecutionLevel": "requireAdministrator"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Office"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
